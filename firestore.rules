rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return isRole('admin') || (request.auth.token.email == "bettiahmart1@gmail.com" && request.auth.token.email_verified == true);
    }

    function isTeacher() {
      return isRole('teacher');
    }

    function isStudent() {
      return isRole('student');
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Users
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isAdmin() || isTeacher() || isOwner(uid));
      allow update: if isAuthenticated() && (isAdmin() || isOwner(uid));
      allow delete: if isAdmin();
    }

    // Homework
    match /homework/{homeworkId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    // Notices
    match /notices/{noticeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    // Attendance
    match /attendance/{attendanceId} {
      allow read: if isAdmin() || isTeacher() || (isStudent() && request.auth.uid == resource.data.studentId);
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    // Leave Requests
    match /leaveRequests/{requestId} {
      allow read: if isAdmin() || isTeacher() || (isStudent() && request.auth.uid == resource.data.studentId);
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAdmin() || isTeacher() || (isStudent() && request.auth.uid == resource.data.studentId && resource.data.status == 'Pending');
      allow delete: if isAdmin() || (isStudent() && request.auth.uid == resource.data.studentId && resource.data.status == 'Pending');
    }

    // Fees
    match /fees/{feeId} {
      allow read: if isAdmin() || (isStudent() && request.auth.uid == resource.data.studentId);
      allow create, update, delete: if isAdmin();
    }

    // Marks
    match /marks/{markId} {
      allow read: if isAdmin() || isTeacher() || (isStudent() && request.auth.uid == resource.data.studentId);
      allow create, update, delete: if isAdmin() || isTeacher();
    }
  }
}
